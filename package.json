{
  "name": "procureflow",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "description": "ProcureFlow - purchase request management demo",
  "author": "ProcureFlow",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "icon": "node scripts/generate-icon.mjs",
    "electron:dev": "cross-env ELECTRON_DEV=1 electron .",
    "electron:build": "npm run icon && npm run build && electron-builder",
    "dist": "npm run electron:build"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@fontsource/manrope": "^5.1.0",
    "lucide-react": "0.562.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@rollup/wasm-node": "^4.61.1",
    "@types/node": "22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "vite": "6.4.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.61.1"
  },
  "build": {
    "appId": "com.procureflow.demo",
    "productName": "ProcureFlow",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ProcureFlow"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Office"
    }
  }
}
